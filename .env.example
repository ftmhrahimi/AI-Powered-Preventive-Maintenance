# ── Backend ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=9700

# ── LLM inference ──
LLM_SERVER_URL=http://localhost:8000/v1/chat/completions
LLM_MODEL_NAME=./

# ── MinIO ──
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pm-photos
MINIO_SECURE=false

# ── Frontend runtime ──
FRONTEND_LLM_URL=http://localhost:9700/api/llm
FRONTEND_EXTRACT_API=http://localhost:9700/extract
FRONTEND_MINIO_BASE=http://localhost:9000/pm-photos
FRONTEND_EXTRACT_PHOTOS=false
FRONTEND_LLM_MODEL=./

# ── PDF photo-fetching ──
PHOTO_MAX_INDEX=50
GPS_RADIUS_METERS=300
DATE_TOLERANCE_DAYS=3
