# ───────────────────────────────────────────────────────────────────────────
# PM Portal — environment configuration
# Copy to ".env" (same folder as docker-compose.yml) and edit before first start:
#     cp .env.example .env
# docker compose reads this file automatically. After changing it you must
# RECREATE the affected containers (a plain restart does NOT reload .env):
#     docker compose up -d
# Values marked **CHANGE** must be set for a real deployment.
# ───────────────────────────────────────────────────────────────────────────

# ── Host ports (left = port on the server, right = inside the container) ──────
FRONTEND_PORT=80           # the URL users open: http://<server>:<FRONTEND_PORT>
BACKEND_PORT=9700          # backend API (only needs to be reachable internally)
MINIO_CONSOLE_PORT=9001    # MinIO admin web console (optional)

# ── LLM (your existing vLLM service — NOT started by this compose) ────────────
# Used by BOTH the backend (photo date/GPS metadata) and the worker (validation).
LLM_SERVER_URL=http://<PRODUCTION_SERVER>:8000/v1/chat/completions   # **CHANGE** to your vLLM endpoint
LLM_MODEL_NAME=./          # must match the model name vLLM was started with
                           # (check: curl http://<vllm-host>:8000/v1/models)
LLM_TIMEOUT_SECONDS=120    # per-request timeout to vLLM
# Validation photos are downscaled to this width before being sent to the LLM
# (browser parity; prevents vLLM 400s on items with many photos). 0 = full size.
LLM_IMAGE_MAX_W=1000

# ── MinIO object storage (photos + metadata) ─────────────────────────────────
MINIO_ACCESS_KEY=CHANGE_ME_minio_user      # **CHANGE**
MINIO_SECRET_KEY=CHANGE_ME_minio_password  # **CHANGE** (min 8 chars)
MINIO_BUCKET=pm-photos

# ── Portal admin accounts ────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_admin_password     # **CHANGE** — primary admin login
# One optional backup admin, seeded on first start (so a locked-out primary
# admin can be recovered: either admin can reset the other from the Users tab).
BACKUP_ADMIN_USERNAME=backupadmin
BACKUP_ADMIN_PASSWORD=CHANGE_ME_backup_password   # **CHANGE** (keep separate & safe)

# ── Worker (the Python processing engine) ────────────────────────────────────
WORKER_CONCURRENCY=3       # how many files process at once (each in its own thread)
WORKER_POLL_SECONDS=5      # how often the worker checks the queue
# The worker calls the backend /extract to pull each PDF's photos + date/GPS
# metadata into MinIO before validating. Keep TRUE — false skips extraction and
# validation would then find no photos. (Only set false if photos are loaded by
# some other process.)
EXTRACT_PHOTOS=true
CHECKBOX_DETECT=true       # detect each row's OK/Not-OK checkbox via the LLM
# Shared secret for the internal /worker/* queue endpoints (defence-in-depth;
# they are not exposed through nginx anyway). Read by both backend and worker.
WORKER_TOKEN=

# ── Validation thresholds (read by the worker + backend) ─────────────────────
GPS_RADIUS_METERS=300      # a photo within this distance of the site = on-site
DATE_TOLERANCE_DAYS=3      # photo date may differ from report date by this many days
PHOTO_MAX_INDEX=50         # max photos checked per checklist item

# ── Frontend runtime config (rendered into config.js at container start) ──────
PUBLIC_BACKEND_URL=        # leave EMPTY: the browser talks same-origin and nginx
                           # proxies /api etc. Only set this if the frontend is
                           # served from a different origin than the backend.
FRONTEND_MINIO_BASE=/pm-photos   # nginx proxies this path to MinIO

# ── Security ─────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=http://<PRODUCTION_SERVER>   # **CHANGE** to the URL users open (CORS)

# ── Container resource caps (so no service starves the host or vLLM) ──────────
# Defaults are conservative; tune to your server (check `free -h` / `nproc`).
# The two heavy services are backend and worker-py (they hold images in memory,
# ×WORKER_CONCURRENCY). vLLM runs outside this stack — these do not touch the GPU.
BACKEND_CPUS=2.0
BACKEND_MEM=3g
WORKER_CPUS=2.0
WORKER_MEM=3g
MINIO_CPUS=1.0
MINIO_MEM=1g
